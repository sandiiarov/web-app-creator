{
  "name": "@workspace/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "vite build --configLoader runner",
    "dev": "vite --configLoader runner",
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@workspace/ui": "workspace:*",
    "almostnode": "catalog:",
    "bippy": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@workspace/oxfmt-config": "workspace:*",
    "@workspace/oxlint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vite-config": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "vite": "catalog:"
  }
}
