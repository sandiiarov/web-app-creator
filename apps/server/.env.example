# Landing-page agent server env sample.
# Copy to `.env` and fill in real values. Real `.env` is gitignored; never
# commit secrets. Nothing throws on a missing key except where noted, but
# OPENROUTER_API_KEY is required for any model run.

# ── OpenRouter (text brain + image gen + vision OCR provider) ────────
# Required for any model calls. Create one at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Base API URL.
# OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Default per-role model ids. Selectable per-project via the model dropdown;
# the default chat model uses OpenRouter's :nitro routing variant.
# OPENROUTER_CHAT_MODEL=z-ai/glm-5.2:nitro
# OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
# OPENROUTER_VISION_MODEL=bytedance-seed/seed-2.0-mini

# ── Agent sampling / cost / retry ────────────────────────────────────
# GLM-5.2 sampling — tune EITHER temperature OR top_p, never both.
# AGENT_TEMPERATURE=1
# AGENT_TOP_P=

# Per-run USD cost cap; 0 disables it. Checked after each cost accrual;
# exceeding it hard-aborts the run with an `error` SSE event.
# AGENT_MAX_COST_USD=1

# Mastra-level model retries own backoff reporting.
# AGENT_MODEL_MAX_RETRIES=0
# AGENT_STREAM_ERROR_MAX_RETRIES=10
# AGENT_RETRY_BASE_DELAY_MS=1000
# AGENT_RETRY_MAX_DELAY_MS=10000

# ── Firecrawl (scrape tool) ──────────────────────────────────────────
# Enables the keyed Firecrawl tier; unset uses the free tier.
# FIRECRAWL_API_KEY=
# Per-scrape cost used for stats accounting.
# FIRECRAWL_CREDIT_USD=0.002

# ── Cloudflare Browser Run (server-side screenshot capture) ──────────
# Required only when the `screenshot` tool is invoked; absent → config error.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ── Mastra platform telemetry (optional) ────────────────────────────
# MASTRA_PROJECT_ID=
# MASTRA_PLATFORM_ACCESS_TOKEN=

# ── Server bind + CORS ──────────────────────────────────────────────
# Bind address. Non-loopback binds are unauthenticated — expose only behind
# an operator-controlled network boundary.
# HOST=127.0.0.1
# PORT=3001
# Exact allowed browser origin; mismatches (incl. null + OPTIONS) → 403.
# CLIENT_ORIGIN=http://localhost:5173
