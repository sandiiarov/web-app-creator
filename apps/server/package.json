{
  "name": "@workspace/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mastra/core": "catalog:",
    "@mastra/duckdb": "catalog:",
    "@mastra/libsql": "catalog:",
    "@mastra/loggers": "catalog:",
    "@mastra/observability": "catalog:",
    "@workspace/conversation": "workspace:*",
    "firecrawl": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@workspace/oxfmt-config": "workspace:*",
    "@workspace/oxlint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-preset": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "vitest": "catalog:"
  }
}
