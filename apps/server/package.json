{
  "name": "@workspace/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "sandbox:build": "docker build -t web-app-creator-sandbox:dev sandbox",
    "sandbox:load": "sbx template load sandbox/web-app-creator-sandbox.tar",
    "sandbox:save": "docker image save web-app-creator-sandbox:dev -o sandbox/web-app-creator-sandbox.tar",
    "sandbox:template": "pnpm run sandbox:build && pnpm run sandbox:save && pnpm run sandbox:load",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@workspace/oxfmt-config": "workspace:*",
    "@workspace/oxlint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-preset": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "vitest": "catalog:"
  }
}
