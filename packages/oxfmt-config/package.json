{
  "name": "@workspace/oxfmt-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "oxfmt": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@workspace/typescript-config": "workspace:*",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
